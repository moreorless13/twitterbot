# Twitter API v2 Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard

# OAuth 2.0 Bearer Token (recommended for API v2)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# OAuth 2.0 Client Credentials (for user authentication)
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 Access Token and Refresh Token (for posting tweets)
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_REFRESH_TOKEN=your_refresh_token_here

# Optional: Tweet Configuration
TWEET_MESSAGE=Hello from my automated Twitter bot!
